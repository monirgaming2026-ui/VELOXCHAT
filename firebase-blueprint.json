{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "fullName", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual text message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text", "status", "createdAt"]
    },
    "FriendShip": {
      "title": "Friendship",
      "description": "Relationship between two users",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the target user" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status", "createdAt"]
    },
    "WorldMessage": {
      "title": "World Message",
      "description": "A message sent to the global world chat room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "text", "createdAt"]
    },
    "CallLog": {
      "title": "Call Log",
      "description": "A record of a voice or video call",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "status": { "type": "string", "enum": ["missed", "completed", "rejected"] },
        "duration": { "type": "number", "description": "Call duration in seconds" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "callerId", "receiverId", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/calls/{callId}": {
      "schema": "CallLog",
      "description": "Stores user call history"
    },
    "/world_messages/{messageId}": {
      "schema": "WorldMessage",
      "description": "Global messages visible to all users"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": "FriendShip",
      "description": "Stores a user's friends list"
    },
    "/usernames/{username}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Ensures global username uniqueness"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Stores chat metadata"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Stores messages within a specific chat"
    }
  }
}
